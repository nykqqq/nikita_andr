  <property name="styleSheet">
   <string notr="true">
   QMainWindow {
           background-image: url(:/images/background.jpg);
           background-repeat: no-repeat;
           background-position: center;
           background-attachment: fixed;
       }
    QPushButton {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
            stop:0 #f5d742, stop:1 #d4a820);
        border: 2px solid #b8860b;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: bold;
        color: #1a1a1a;
        min-width: 80px;
    }
    QPushButton:hover {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
            stop:0 #ffe44d, stop:1 #e8b830);
        border-color: #d4a020;
    }
    QPushButton:pressed {
        background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
            stop:0 #d4a820, stop:1 #b8860b);
    }
    QPushButton:disabled {
        background: #666666;
        border-color: #444444;
        color: #999999;
    }
    QLabel {
        color: white;
        font-size: 16px;
        font-weight: bold;
    }
    QLabel#scoreLabel {
        font-size: 20px;
        color: #ffd700;
    }
    QLabel#statusLabel {
        font-size: 24px;
        color: #ff4444;
        background: rgba(0,0,0,0.5);
        border-radius: 10px;
        padding: 10px;
    }
    QLabel#betLabel {
        font-size: 18px;
        color: #00ff00;
    }
    /* Стиль для заголовка */
    QLabel#titleLabel {
        font-size: 36px;
        font-weight: bold;
        color: #ffd700;
        background: rgba(0,0,0,0.3);
        border: 2px solid #ffd700;
        border-radius: 15px;
        padding: 10px;
        letter-spacing: 5px;
    }
   </string>
